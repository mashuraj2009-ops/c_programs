#include<stdio.h>
#include<strings.h>

typedef struct{
    int id;
    char name[20];
    float salary;

}employee;

int main(){
    employee list[3];

    printf("---ENTER EMPLOYEE DETAILS---\n");
    for(int i=0;i<3;i++){
       printf("\nEmployee %d:\n", i + 1);

        printf("ID :");
        scanf("%d",&list[i].id);

        printf("NAME :");
        scanf("%s",list[i].name);

        printf("SALARY :");
        scanf("%f",&list[i].salary);
    }

    printf("employee details\n");

    for(int i=0;i<3;i++){
        printf("ID : %d\n",list[i].id);
        printf("NAME : %s\n",list[i].name);
        printf("SALARY : %f\n",list[i].salary);
        
    }
return 0;
    
}



