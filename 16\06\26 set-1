//palindrome

#include<stdio.h>
int main(){
    int n;
    int remainder,org_num,rev=0;

    printf("enter a number\n");
    scanf("%d",&n);

    org_num=n;

    while(n>0){
        remainder=n % 10;
        rev = rev*10+remainder;
        n /=10;}


if(org_num==rev){
            printf("%d is a palindrome number\n",org_num);
        }

            else{printf("%d is not a palindrome number\n",org_num);
            
            
            }


        }
