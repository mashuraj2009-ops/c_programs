#include <stdio.h>

int main() {
    int qty[5] = {50, 22, 85, 40, 12};
    int *ptr = qty; 

    
    printf("Original Quantities:\n");
    for (int i = 0; i < 5; i++) {
        printf("Product %d: %d\n", i + 1, *(ptr + i));
    }

    
    for (int i = 0; i < 5; i++) {
        *(ptr + i) = *(ptr + i) + 10;
    }

    
    printf("\nUpdated Quantities (Added 10):\n");
    for (int i = 0; i < 5; i++) {
        printf("Product %d: %d\n", i + 1, *(ptr + i));
    }

    return 0;
}



