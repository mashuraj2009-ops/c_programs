#include <stdio.h>

int main() {
    int marks[5];
    int sum = 0;
    float average;

    
    printf("Enter marks of 5 students:\n");
    for (int i = 0; i < 5; i++) {
        scanf("%d", &marks[i]);
    }

    
    for (int i = 0; i < 5; i++) {
        sum += marks[i]; 
    }

    
    average = sum / 5.0;

    printf("Average Mark: %.2f\n", average);

    return 0;
}



