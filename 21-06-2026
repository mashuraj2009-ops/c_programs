#include<stdio.h>

struct emp{
    int id;
    char name[20];
    int salary;
};

int main(){
    struct emp list[5];
    int a=0;
    int max=0; 

    printf("---ENTER EMPLOYEE DETAILS---\n");
    for(int i=0;i<5;i++){
        printf("EMPLOYEE %d:\n",i+1);
        
        printf("ID :\n");
        scanf("%d",&list[i].id);

        printf("NAME :\n");
        scanf("%s",list[i].name);

        printf("SALARY :\n");
        scanf("%d",&list[i].salary);
    }

    printf("---EMPLOYEE DETAILS---\n");
    for(int i=0;i<5;i++){
        printf("ID : %d\n",list[i].id);
        printf("NAME : %s\n",list[i].name);
        printf("SALARY :%d\n",list[i].salary);
    }

    
    for(int i=0;i<5;i++){
        if(list[i].salary > a){
            a = list[i].salary;
            max = i; 
        }
    }


    printf("\n---EMPLOYEE WITH THE HIGHEST SALARY---\n");
    printf("ID     : %d\n", list[max].id);
    printf("NAME   : %s\n", list[max].name);
    printf("SALARY : %d\n", list[max].salary);

    return 0;
}



