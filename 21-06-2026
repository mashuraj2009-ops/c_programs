#include <stdio.h>


struct Product {
    char name[50];
    float price;
};

int main() {
    
    struct Product item[3] = {
        {"Milk", 62},
        {"Bread", 60},
        {"Eggs", 7.5}
    };

    float totalBill = 0;

    
    printf("--- Shopping Bill ---\n");
    for (int i = 0; i < 3; i++) {
        printf("%s: %.2f\n", item[i].name, item[i].price);
        totalBill += item[i].price; 
    }


    printf("---------------------\n");
    printf("Total Bill: %.2f\n", totalBill);

    return 0;
}



